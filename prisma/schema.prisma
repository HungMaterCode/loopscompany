generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String?
  name      String
  role      String   @default("user")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  avatar    String?
  googleId  String?  @unique
}

model SiteSetting {
  id        String   @id @default("default")
  config    Json
  updatedAt DateTime @updatedAt
}

model SeoPage {
  id            String   @id @default(cuid())
  pageId        String   @unique
  label         String
  title         String
  description   String
  keywords      String?
  ogTitle       String?
  ogDescription String?
  canonical     String
  ogImage       String?
  robots        String   @default("index, follow")
  updatedAt     DateTime @updatedAt
}

model Article {
  id            String   @id @default(cuid())
  slug          String   @unique
  category      String
  categoryColor String   @default("#16a34a")
  title         String
  excerpt       String
  content       String
  cover         String
  coverPublicId String?
  author        String
  authorRole    String
  publishedAt   DateTime
  readTime      Int      @default(5)
  tags          String[]
  published     Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model ContactLead {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  message   String
  source    String   @default("website")
  createdAt DateTime @default(now())
}

model TeamMember {
  id          String   @id @default(cuid())
  name        String
  role        String
  avatar      String
  years       Int
  badge       String
  bio         String
  skills      String[]
  isSpotlight Boolean  @default(false)
  specialty   String?
  order       Int      @default(0)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Project {
  id        String   @id
  num       String
  title     String
  category  String
  year      String
  result    String
  img       String
  accent    String
  url       String?
  createdAt DateTime @default(now())
}
