generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String?
  name      String
  role      String   @default("user")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  avatar    String?
  googleId  String?  @unique
}

model SiteSetting {
  id        String   @id @default("default")
  config    Json
  updatedAt DateTime @updatedAt
}

model SeoPage {
  id            String   @id @default(cuid())
  pageId        String   @unique
  label         String
  title         String
  description   String
  keywords      String?
  ogTitle       String?
  ogDescription String?
  canonical     String
  ogImage       String?
  robots        String   @default("index, follow")
  updatedAt     DateTime @updatedAt
}

model Article {
  id            String   @id @default(cuid())
  slug          String   @unique
  category      String
  categoryColor String   @default("#16a34a")
  title         String
  excerpt       String
  content       String
  cover         String
  coverPublicId String?
  author        String
  authorRole    String
  publishedAt   DateTime
  readTime      Int      @default(5)
  tags          String[]
  published     Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model ContactLead {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  message   String
  source    String   @default("website")
  createdAt DateTime @default(now())
  status    String   @default("Mới")
  details   Json?
}

model TeamMember {
  id          String   @id @default(cuid())
  name        String
  role        String
  roleEn      String   @default("")
  avatar      String
  years       Int
  badge       String   @default("")
  projects    Int      @default(0)
  bio         String   @db.Text
  skills      String[]
  gradient    String   @default("linear-gradient(145deg, #2A2520 0%, #1A1A1A 50%, #3A3530 100%)")
  email       String   @default("")
  zalo        String?
  facebook    String?
  phone       String?
  order       Int      @default(0)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Project {
  id           String   @id @default(cuid())
  num          String
  title        String
  slug         String?  @unique
  category     String
  year         String
  result       String
  img          String
  accent       String
  url          String?
  
  // Chi tiết dự án
  overview     String?  @db.Text
  challenge    String?  @db.Text
  solution     String?  @db.Text
  roles        String[]
  mockupImg    String?
  solutionImg1 String?
  solutionImg2 String?

  createdAt    DateTime @default(now())
}

model WebPage {
  id        String   @id @default(cuid())
  code      String   @unique
  name      String
  tag       String
  subtitle  String
  price     Int
  cover     String
  icon      String
  highlight Boolean  @default(false)
  features  String[]
  missing   String[]
  order     Int      @default(0)
  active    Boolean  @default(true)
  isRental  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Domain {
  id        String   @id @default(cuid())
  label     String
  price     Int
  order     Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Hosting {
  id        String   @id @default(cuid())
  label     String
  price     Int
  order     Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SeoPackage {
  id          String   @id @default(cuid())
  label       String
  description String
  price       Int
  order       Int      @default(0)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Service {
  id        String   @id @default(cuid())
  label     String   // Tên dịch vụ
  sub       String   // Mô tả ngắn
  img       String   // Link ảnh nền
  tags      String[] // Các tag phụ
  size      String   @default("small") // "small" hoặc "large"
  glassBg   String?  // Hiệu ứng kính (rgba hoặc gradient)
  link      String   @default("/coming-soon") // Đường dẫn chuyển trang
  order     Int      @default(0) // Sắp xếp
  active    Boolean  @default(true) // Trạng thái kích hoạt
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Order {
  id        String   @id @default(cuid())
  code      String   @unique
  name      String
  email     String
  phone     String?
  type      String
  details   Json
  status    String   @default("pending")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Cloud {
  id          Int      @id @default(autoincrement())
  label       String
  price       Int
  price1Year  Int
  price3Years Int
  order       Int      @default(0)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

